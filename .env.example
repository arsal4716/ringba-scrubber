# ─── Core ─────────────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/ringba-scrub
PORT=5000
APP_TIMEZONE=Asia/Karachi
CORS_ORIGIN=http://localhost:5173
FILE_RETENTION_DAYS=7
ADMIN_PASSWORD=change-me

# ─── Ringba report API (number fetching — Token auth) ─────────
RINGBA_API_URL=https://api.ringba.com/v2/<ACCOUNT_ID>/calllogs
RINGBA_TOKEN=your-ringba-api-token
# RINGBA_PAGE_SIZE=1000

# ─── Ringba Bulk Tag / Ping-tree upload (Bearer auth) ─────────
# Account-scoped v2 API used to upload the suppression file as a Bulk
# Tag and re-point a ping-tree target at it. Falls back to RINGBA_TOKEN
# if RINGBA_BULK_TOKEN is not set.
RINGBA_ACCOUNT_ID=RAec22abec294c46ddba910daf69d8489c
RINGBA_BULK_API_BASE=https://api.ringba.com/v2
# RINGBA_BULK_TOKEN=your-ringba-api-token

# ─── QC tools (callcheckai.com) ───────────────────────────────
QC_API_BASE=https://callcheckai.com/api
QC_API_EMAIL=you@example.com
QC_API_PASSWORD=your-password
# QC_API_TIMEOUT_MS=60000

# ─── CallGrid ( GET {BASE}/call?organizationId=... , Bearer auth) ─
# When all three are set AND the callgrid source is enabled in
# config/constants.js, the daily run fetches from CallGrid too.
# Leave the token/org blank to skip CallGrid safely.
CALLGRID_API_BASE=https://api.callgrid.com/api
CALLGRID_API_TOKEN=
CALLGRID_ORG_ID=cmovn1ljg00oy07h3reijtrfg
# CALLGRID_REPORT_TZ=US/Eastern
# CALLGRID_PAGE_SIZE=500
# CALLGRID_MAX_PAGES=400

# ─── Aurionx buyer-dedup API (SSDI scrub) ────────────────────
# Used during the publisher SSDI scrub to flag buyer-side duplicates.
# Defaults match the known campaign; override if they rotate.
# AURIONX_API_BASE=https://api.aurionx.ai/api/vendors/leads/check
# AURIONX_CAMPAIGN_KEY=c2cc5f885d2a3790c85b9c1bde3fa2c3
# AURIONX_API_KEY=kdmr5
# AURIONX_CONCURRENCY=120
# AURIONX_TIMEOUT_MS=12000
# AURIONX_MAX_RETRIES=2
# AURIONX_CACHE_TTL_MS=1800000

# ─── IdealConcept report (Ringba + CallGrid unique caller IDs) ─
# Ringba: caller IDs where targetName CONTAINS this term.
# IDEALCONCEPT_RINGBA_SEARCH=IdealConcept
# CallGrid: if you have the IdealConcept campaign id(s), set them here and
# the API filters server-side; otherwise it filters rows whose
# destination/source/campaign name contains IDEALCONCEPT_NAME_CONTAINS.
# IDEALCONCEPT_CALLGRID_CAMPAIGN_IDS=
# IDEALCONCEPT_NAME_CONTAINS=IdealConcept
# Keep only "Rejected - Duplicate" CallGrid records (default true). When
# true, Ringba is skipped (its call logs have no duplicate field).
# IDEALCONCEPT_DUPLICATE_ONLY=true

# ─── Kaliper MCP (Suppressed CallerID report) ─────────────────
# Bearer token for the Kaliper MCP server. Required for the
# "Run Now" button on the Kaliper page.
KALIPER_TOKEN=
# KALIPER_URL=https://app-0.thekaliper.com/mcp
# KALIPER_TIMEZONE=America/New_York
# KALIPER_PAGE_SIZE=100
# KALIPER_DELAY_MS=250
# KALIPER_LM_TARGETS=44629,44628,43527
# KALIPER_HC_TARGETS=43523,43664,44626

# ─── Google Sheets ───────────────────────────────────────────
# Path to the service-account JSON (defaults to config/sheet.json)
# GOOGLE_SHETS_CREDENTIALS=./config/sheet.json
